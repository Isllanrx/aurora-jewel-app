# Aurora Joias — Configuração de Credenciais

# Como configurar:
#   1. Crie um projeto em https://supabase.com
#   2. Execute as migrations em ordem: supabase/migrations/001 → 005
#   3. Acesse Settings → API no Supabase Dashboard
#   4. Cole os valores abaixo em lib/supabase.js (linhas 4-5)

SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_API_KEY=SUA_CHAVE_ANON_AQUI
